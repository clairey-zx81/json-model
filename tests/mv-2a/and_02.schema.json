{
  "description": "merge object stuff if possible",
  "allOf": [
    {
      "type": "object",
      "patternProperties": {
        "^z": true,
        "^d[a-z]": {
          "type": "string"
        }
      },
      "properties": {
        "s": {
          "type": "string"
        },
        "u": {
          "type": "integer",
          "minimum": 1
        },
        "b": {
          "type": "boolean"
        },
        "f": {
          "type": "number",
          "exclusiveMinimum": 0.0
        }
      },
      "required": [
        "s",
        "b",
        "f"
      ],
      "additionalProperties": true
    },
    {
      "type": "object",
      "patternProperties": {
        "^d[0-9]": {
          "type": "integer",
          "minimum": 1
        }
      },
      "additionalProperties": true
    }
  ]
}
